{minimum_otp_vsn, "28"}.

{erl_opts, [
    debug_info,
    warnings_as_errors,
    warn_missing_spec
]}.

{deps, [
    %% TODO: Switch to hex once arizona_core is published: {arizona_core, "~> 0.1"}
    {arizona_core, {git, "https://github.com/Taure/arizona_core.git", {branch, "main"}}},
    {cowboy, "2.14.2"}
]}.

{hex, [{doc, #{provider => ex_doc}}]}.

% See https://github.com/ninenines/cowboy/issues/1670
{overrides, [{override, cowboy, [{deps, [{cowlib, "~> 2.15"}, {ranch, "~> 2.0"}]}]}]}.

{dialyzer, [
    {plt_apps, all_deps},
    {plt_extra_apps, [
        arizona_core,
        cowboy,
        cowlib,
        ranch
    ]},
    {warnings, [
        unknown,
        unmatched_returns
    ]}
]}.

{profiles, [
    {test, [
        {erl_opts, [
            debug_info,
            nowarn_missing_spec,
            warnings_as_errors
        ]},
        {extra_src_dirs, [{"test", [{recursive, true}]}]},
        {xref_checks, []}
    ]}
]}.

{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used,
    deprecated_function_calls,
    deprecated_functions
]}.

{cover_enabled, true}.

{project_plugins, [
    covertool,
    rebar3_audit,
    {rebar3_sbom, {git, "https://github.com/Taure/rebar3_sbom.git", {branch, "feat/include-otp-components"}}},
    {erlfmt, "1.7.0"},
    {rebar3_hex, "~> 7.0"},
    {rebar3_ex_doc, "~> 0.2"}
]}.

{ex_doc, [
    {source_url, ~"https://github.com/novaframework/arizona_nova"},
    {extras, [~"README.md", ~"LICENSE"]},
    {main, ~"readme"},
    {proglang, erlang},
    {api_reference, true}
]}.

{erlfmt, [
    write,
    {files, [
        "rebar.config",
        "src/*.app.src",
        "src/**/*.erl",
        "test/**/*.erl"
    ]}
]}.
